# Lumina Ops — Environment Variables
# Copy to .env and fill in values before running

# Go API server base URL (used for testing)
# Example (local Go backend):
VITE_API_URL=http://localhost:8080/api/v1

# Public URL where the client assessment form is hosted
# Used to generate tokenized links sent to clients via email/SMS
VITE_ASSESS_URL=https://ops.luminatherapyalliance.com

# Stripe publishable key (for Stripe.js on frontend if needed)
VITE_STRIPE_PK=pk_live_...
